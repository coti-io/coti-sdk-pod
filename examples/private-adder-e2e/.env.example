# Required for e2e
SEPOLIA_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com
COTI_TESTNET_RPC_URL=https://testnet.coti.io/rpc

# Wallet + AES key (aliases supported: PRIVATE_KEY_ACCOUNT_2, USER_AES_KEY_2)
SEPOLIA_PRIVATE_KEY=0x...
POD_ACCOUNT_AES_KEY=...

# Optional — hybrid deploy (auto-written after `npm run deploy`)
PRIVATE_ADDER_SEPOLIA_ADDRESS=
POD_ENCRYPTION_NETWORK=testnet
DEPLOY_ON_MISSING=true

# Polling
POD_E2E_POLL_INTERVAL_MS=5000
POD_E2E_TIMEOUT_MS=300000
