# Integration test configuration (copy to `.env` and fill in values).
# Run: npm run test:integ

# PoD network for encryption-service tests (default: testnet)
POD_TEST_NETWORK=testnet

# Override encryption service base URL (optional).
# Defaults:
#   testnet — https://fullnode.testnet.coti.io/pod-encryption
#   mainnet — https://pod-encryption-service-mainnet.coti.io
# POD_ENCRYPTION_SERVICE_URL=

# Sepolia JSON-RPC URL — required for PodRequest integration tests
SEPOLIA_RPC_URL=

# Coti testnet JSON-RPC URL — required for PodRequest integration tests
COTI_TESTNET_RPC_URL=
